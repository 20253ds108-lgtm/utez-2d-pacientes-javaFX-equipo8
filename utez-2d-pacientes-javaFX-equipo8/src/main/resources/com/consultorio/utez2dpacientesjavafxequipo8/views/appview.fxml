<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.*?>

<AnchorPane prefHeight="450.0" prefWidth="600.0" xmlns="http://javafx.com/javafx/17.0.12" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.consultorio.utez2dpacientesjavafxequipo8.AppViewController">
    <children>
        <Label layoutX="14.0" layoutY="14.0" prefHeight="31.0" prefWidth="306.0" text="Formulario de consultorio" textFill="#944e7b">
            <font>
                <Font name="System Italic" size="22.0" />
            </font>
        </Label>

        <Button fx:id="btnGuardar" layoutX="96.0" layoutY="310.0" mnemonicParsing="false" onAction="#clicEnGuardar" prefHeight="25.0" prefWidth="154.0" text="Guardar" textFill="#0e9002" />
        <Button fx:id="btnCancelar" layoutX="359.0" layoutY="310.0" mnemonicParsing="false" onAction="#clicEnCancelar" prefHeight="25.0" prefWidth="161.0" text="Cancelar" textFill="#fc0303" />

        <Label fx:id="lblError" layoutX="34.0" layoutY="270.0" prefHeight="25.0" prefWidth="519.0" textAlignment="CENTER" textFill="RED">
            <font>
                <Font name="System Bold" size="14.0" />
            </font>
        </Label>

        <GridPane layoutX="34.0" layoutY="46.0" prefHeight="207.0" prefWidth="519.0">
            <columnConstraints>
                <ColumnConstraints hgrow="SOMETIMES" minWidth="10.0" prefWidth="100.0" />
                <ColumnConstraints hgrow="SOMETIMES" minWidth="10.0" prefWidth="100.0" />
            </columnConstraints>
            <rowConstraints>
                <RowConstraints minHeight="10.0" prefHeight="30.0" vgrow="SOMETIMES" />
                <RowConstraints minHeight="10.0" prefHeight="30.0" vgrow="SOMETIMES" />
                <RowConstraints minHeight="10.0" prefHeight="30.0" vgrow="SOMETIMES" />
                <RowConstraints minHeight="10.0" prefHeight="30.0" vgrow="SOMETIMES" />
                <RowConstraints minHeight="10.0" prefHeight="30.0" vgrow="SOMETIMES" />
                <RowConstraints minHeight="10.0" prefHeight="30.0" vgrow="SOMETIMES" />
            </rowConstraints>
            <children>
                <Label text="CURP:" />
                <Label text="Nombre:" GridPane.rowIndex="1" />
                <Label text="Edad:" GridPane.rowIndex="2" />

                <Label text="Telefono:" GridPane.rowIndex="3">
                    <GridPane.margin>
                        <Insets right="6.0" left="0.0" top="0.0" bottom="0.0" />
                    </GridPane.margin>
                </Label>

                <Label text="Alergias:" GridPane.rowIndex="4" />

                <TextField fx:id="txtCurp" GridPane.columnIndex="1" />
                <TextField fx:id="txtNombre" GridPane.columnIndex="1" GridPane.rowIndex="1" />
                <TextField fx:id="txtEdad" GridPane.columnIndex="1" GridPane.rowIndex="2" />
                <TextField fx:id="txtTelefono" GridPane.columnIndex="1" GridPane.rowIndex="3" />
                <TextField fx:id="txtAlergias" prefHeight="24.0" prefWidth="278.0" GridPane.columnIndex="1" GridPane.rowIndex="4" />
            </children>
        </GridPane>
    </children>
</AnchorPane>